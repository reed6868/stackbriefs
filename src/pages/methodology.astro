---
import { getEntry, render } from "astro:content";

import { seoIndexableFromEnvironment } from "../content/seo-context";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = await getEntry("pages", "methodology");
if (!page) throw new Error("Methodology page content is required");
const { Content } = await render(page);
const indexable = seoIndexableFromEnvironment();
---

<BaseLayout
  title={`${page.data.title} | StackBriefs`}
  description={page.data.description}
  indexable={indexable}
  canonicalPath="/methodology"
  reading
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Methodology" }]}
  structuredData={{ kind: "webpage" }}
>
  <article class="trusted-content">
    <header class="trusted-content__header">
      <h1>{page.data.title}</h1>
      <p class="trusted-content__lede">{page.data.description}</p>
      <p class="trusted-content__meta">
        Last reviewed <time datetime={page.data.lastReviewedAt}>{page.data.lastReviewedAt}</time>
      </p>
    </header>
    <Content />
  </article>
</BaseLayout>
