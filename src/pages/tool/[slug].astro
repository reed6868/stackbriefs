---
import { assembleContentCollections } from "../../content/assemble";
import { publicationOptionsFromEnvironment } from "../../content/build-context";
import LifecycleStatusPage from "../../components/LifecycleStatusPage.astro";
import ToolDetail from "../../components/tool/ToolDetail.astro";
import {
  projectToolRoutePaths,
  type ToolRoute,
} from "../../domain/lifecycle-routes";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  route: ToolRoute;
}

export async function getStaticPaths() {
  const publication = await assembleContentCollections(publicationOptionsFromEnvironment());
  return projectToolRoutePaths(publication);
}

const { route } = Astro.props;
---

{route.kind === "published" ? (
  <BaseLayout
    title={`${route.detail.tool.name} | StackBriefs`}
    description={`${route.detail.tool.summary} Review published Scenario contexts, limitations, hands-on status, and verification steps.`}
  >
    <ToolDetail detail={route.detail} />
  </BaseLayout>
) : (
  <LifecycleStatusPage route={route} />
)}
