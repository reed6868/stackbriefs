---
import { assembleContentCollections } from "../../content/assemble";
import { publicationOptionsFromEnvironment } from "../../content/build-context";
import ToolDetail from "../../components/tool/ToolDetail.astro";
import { projectToolDetailPaths, type ToolDetailProjection } from "../../domain/tool-detail";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  detail: ToolDetailProjection;
}

export async function getStaticPaths() {
  const publication = await assembleContentCollections(publicationOptionsFromEnvironment());
  return projectToolDetailPaths(publication);
}

const { detail } = Astro.props;
---

<BaseLayout
  title={`${detail.tool.name} | StackBriefs`}
  description={`${detail.tool.summary} Review published Scenario contexts, limitations, hands-on status, and verification steps.`}
>
  <ToolDetail detail={detail} />
</BaseLayout>
