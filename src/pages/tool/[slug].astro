---
import { assembleContentCollections } from "../../content/assemble";
import { publicationOptionsFromEnvironment } from "../../content/build-context";
import type { ToolContent } from "../../content/schema";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  tool: ToolContent;
}

export async function getStaticPaths() {
  const publication = await assembleContentCollections(publicationOptionsFromEnvironment());
  return publication.toolOutcomes.flatMap((outcome) =>
    outcome.kind === "exposed-tool"
      ? [{ params: { slug: outcome.slug }, props: { tool: outcome.tool } }]
      : [],
  );
}

const { tool } = Astro.props;
---

<BaseLayout
  title={`${tool.name} | StackBriefs`}
  description="Non-production fixture for the StackBriefs Tool route."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: tool.name }]}
>
  <article data-fixture={tool.fixture ? "true" : undefined}>
    <p class="fixture-label">{tool.fixture ? "Fixture preview" : "Published Tool"}</p>
    <h1>{tool.name}</h1>
    <p>{tool.summary}</p>
    <h2>Route skeleton</h2>
    <p>
      Evidence, limitations, hands-on status, and outbound-link separation are intentionally deferred. This page does not make a fit claim or name a winner.
    </p>
    <p class="route-actions"><a href="/#scenarios">Browse fixture Scenarios</a></p>
  </article>
</BaseLayout>
