---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="StackBriefs"
  description="Scenario-first AI tool decision support."
>
  <section id="scenarios" aria-labelledby="home-title" data-fixture="true">
    <p class="fixture-label">Fixture preview</p>
    <h1 id="home-title">Start with a use case. Narrow the options. Choose with confidence.</h1>
    <p>
      The P0 route skeleton is available with non-production fixture content. Scenario discovery and decision logic arrive through later reviewed tasks.
    </p>
    <p class="route-actions"><a href="/decision/fixture-scenario">Open the fixture Scenario</a></p>
  </section>
</BaseLayout>
