---
import ScenarioRow from "../components/ScenarioRow.astro";
import { assembleContentCollections } from "../content/assemble";
import { publicationOptionsFromEnvironment } from "../content/build-context";
import { seoIndexableFromEnvironment } from "../content/seo-context";
import { sortHomeScenarios, type HomeScenario } from "../domain/home-discovery";
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  scenarios?: readonly HomeScenario[];
}

async function loadPublishedScenarios() {
  const publication = await assembleContentCollections(publicationOptionsFromEnvironment());
  return publication.scenarioOutcomes.flatMap((outcome) =>
    outcome.kind === "published"
      ? [{
          slug: outcome.slug,
          title: outcome.scenario.title,
          goal: outcome.scenario.goal,
          prerequisite: outcome.scenario.prerequisites.join(" "),
          suitableFor: outcome.scenario.suitableFor,
          notSuitableFor: outcome.scenario.notSuitableFor,
          candidateCount: outcome.scenario.candidates.length,
          dimensionCount: outcome.scenario.dimensions.length,
          lastReviewedAt: outcome.scenario.lastReviewedAt,
          fixture: outcome.fixture,
        }]
      : [],
  );
}

const scenarios = sortHomeScenarios(Astro.props.scenarios ?? await loadPublishedScenarios());
const fixturePreview = scenarios.some((scenario) => scenario.fixture);
const indexable = seoIndexableFromEnvironment();
---

<BaseLayout
  title="StackBriefs — scenario-first AI tool decisions"
  description="Start with a use case, narrow the options, and verify AI-tool trade-offs."
  indexable={indexable}
  canonicalPath="/"
  structuredData={{ kind: "website" }}
>
  <header class="home-hero" aria-labelledby="home-title" data-fixture={fixturePreview ? "true" : undefined}>
    <p class="fixture-label">{fixturePreview ? "Fixture preview" : "Decision workspace"}</p>
    <h1 id="home-title">Start with a use case. Narrow the options. Choose with confidence.</h1>
    <p>
      Compare AI tools inside a concrete decision context, with explicit boundaries, current evidence, and no universal winner.
    </p>
    <a class="home-hero__action" href="#scenarios">Browse scenarios</a>
  </header>

  <section id="scenarios" class="home-section" aria-labelledby="scenarios-title" data-fixture={fixturePreview ? "true" : undefined}>
    <div class="home-section__heading">
      <p class="fixture-label">Scenario discovery</p>
      <h2 id="scenarios-title">Choose the decision you are making</h2>
      <p>Each Scenario defines a different goal, boundary, and set of decision dimensions.</p>
    </div>
    <div class="scenario-list">
      {scenarios.map((scenario) => <ScenarioRow scenario={scenario} />)}
    </div>
  </section>

  <section id="how-it-works" class="home-section" aria-labelledby="process-title">
    <div class="home-section__heading">
      <p class="fixture-label">How it works</p>
      <h2 id="process-title">Narrow, compare, verify</h2>
    </div>
    <ol class="process-list">
      <li><strong>Narrow</strong><span>Set the required conditions for this Scenario.</span></li>
      <li><strong>Compare</strong><span>Inspect equal, Scenario-scoped trade-offs without a winner column.</span></li>
      <li><strong>Verify</strong><span>Check evidence state, scope, limitations, and review date before leaving.</span></li>
    </ol>
  </section>

  <section id="trust" class="home-section trust-strip" aria-labelledby="trust-title">
    <div>
      <p class="fixture-label">Trust</p>
      <h2 id="trust-title">Understand the method and commercial boundary</h2>
      <p>Matching and evidence rules remain separate from Affiliate relationships.</p>
    </div>
    <nav aria-label="Trust">
      <a href="/methodology">Read the Methodology</a>
      <a href="/affiliate-disclosure">Read the Affiliate disclosure</a>
    </nav>
  </section>
</BaseLayout>
