---
import { assembleContentCollections } from "../../content/assemble";
import { publicationOptionsFromEnvironment } from "../../content/build-context";
import DecisionWorkspace from "../../components/decision/DecisionWorkspace.astro";
import LifecycleStatusPage from "../../components/LifecycleStatusPage.astro";
import { evaluateDecision } from "../../domain/decision";
import {
  projectScenarioRoutePaths,
  type ScenarioRoute,
} from "../../domain/lifecycle-routes";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  route: ScenarioRoute;
}

export async function getStaticPaths() {
  const publication = await assembleContentCollections(publicationOptionsFromEnvironment());
  return projectScenarioRoutePaths(publication);
}

const { route } = Astro.props;
const evaluation = route.kind === "published" ? evaluateDecision(route.scenario, []) : undefined;
---

{route.kind === "published" && evaluation ? (
  <BaseLayout
    title={`${route.scenario.title} | StackBriefs`}
    description={`${route.scenario.goal} Review Scenario boundaries, decision criteria, evidence, and limitations.`}
    breadcrumbs={[{ label: "Home", href: "/" }, { label: route.scenario.title }]}
  >
    <DecisionWorkspace scenario={route.scenario} evaluation={evaluation} />
    <p class="decision-return"><a href="/#scenarios">Browse all Scenarios</a></p>
  </BaseLayout>
) : route.kind === "status" ? (
  <LifecycleStatusPage route={route} />
) : null}
