---
import type { HomeScenario } from "../../fixtures/home-scenarios";
import { homeScenarios } from "../../fixtures/home-scenarios";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  scenario: HomeScenario;
}

export function getStaticPaths() {
  return homeScenarios.map((scenario) => ({
    params: { scenario: scenario.slug },
    props: { scenario },
  }));
}

const { scenario } = Astro.props;
---

<BaseLayout
  title={`${scenario.title} | StackBriefs`}
  description="Non-production fixture for the StackBriefs Decision route."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: scenario.title }]}
>
  <article data-fixture="true">
    <p class="fixture-label">Fixture preview</p>
    <h1>{scenario.title}</h1>
    <p>{scenario.goal}</p>
    <h2>Route skeleton</h2>
    <p>
      This non-production fixture reserves the Scenario boundary, criteria, result, exclusion, and recovery regions. Deterministic decision behavior arrives in later reviewed tasks.
    </p>
    <p class="route-actions"><a href="/#scenarios">Browse fixture Scenarios</a></p>
  </article>
</BaseLayout>
