---
import { assembleContentCollections } from "../../content/assemble";
import { publicationOptionsFromEnvironment } from "../../content/build-context";
import type { DomainScenario } from "../../domain/model";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  scenario: DomainScenario;
}

export async function getStaticPaths() {
  const publication = await assembleContentCollections(publicationOptionsFromEnvironment());
  return publication.scenarioOutcomes.flatMap((outcome) =>
    outcome.kind === "published"
      ? [{ params: { scenario: outcome.slug }, props: { scenario: outcome.scenario } }]
      : [],
  );
}

const { scenario } = Astro.props;
---

<BaseLayout
  title={`${scenario.title} | StackBriefs`}
  description="Non-production fixture for the StackBriefs Decision route."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: scenario.title }]}
>
  <article data-fixture={scenario.fixture ? "true" : undefined}>
    <p class="fixture-label">{scenario.fixture ? "Fixture preview" : "Published Scenario"}</p>
    <h1>{scenario.title}</h1>
    <p>{scenario.goal}</p>
    <h2>Route skeleton</h2>
    <p>
      This non-production fixture reserves the Scenario boundary, criteria, result, exclusion, and recovery regions. Deterministic decision behavior arrives in later reviewed tasks.
    </p>
    <p class="route-actions"><a href="/#scenarios">Browse fixture Scenarios</a></p>
  </article>
</BaseLayout>
