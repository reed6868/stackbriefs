---
import { assembleContentCollections } from "../../content/assemble";
import { publicationOptionsFromEnvironment } from "../../content/build-context";
import DecisionWorkspace from "../../components/decision/DecisionWorkspace.astro";
import { evaluateDecision } from "../../domain/decision";
import type { DomainScenario } from "../../domain/model";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  scenario: DomainScenario;
}

export async function getStaticPaths() {
  const publication = await assembleContentCollections(publicationOptionsFromEnvironment());
  return publication.scenarioOutcomes.flatMap((outcome) =>
    outcome.kind === "published"
      ? [{ params: { scenario: outcome.slug }, props: { scenario: outcome.scenario } }]
      : [],
  );
}

const { scenario } = Astro.props;
const evaluation = evaluateDecision(scenario, []);
---

<BaseLayout
  title={`${scenario.title} | StackBriefs`}
  description={`${scenario.goal} Review Scenario boundaries, decision criteria, evidence, and limitations.`}
  breadcrumbs={[{ label: "Home", href: "/" }, { label: scenario.title }]}
>
  <DecisionWorkspace scenario={scenario} evaluation={evaluation} />
  <p class="decision-return"><a href="/#scenarios">Browse all Scenarios</a></p>
</BaseLayout>
