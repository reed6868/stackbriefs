---
import { isCurrentPage, shellNavigation } from "./navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner site-container">
    <div>
      <a class="site-brand" href="/">StackBriefs</a>
      <p>Scenario-first AI tool decision support.</p>
    </div>
    <nav aria-label="Footer">
      <ul>
        {
          shellNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isCurrentPage(item.href, currentPath) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <p class="site-footer__copyright">© {year} StackBriefs</p>
  </div>
</footer>
