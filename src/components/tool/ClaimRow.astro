---
import EvidenceBadge from "../decision/EvidenceBadge.astro";
import { formatDimensionValue } from "../decision/presentation";
import type { ToolClaimProjection } from "../../domain/tool-evidence";

interface Props {
  claim: ToolClaimProjection;
}

const { claim } = Astro.props;
const scopeLabels = {
  plan: "Plan",
  region: "Region",
  platform: "Platform",
  version: "Version",
} as const;
const sourceTypeLabel = (sourceType: string) => sourceType
  .split("_")
  .map((part) => part[0]?.toUpperCase() + part.slice(1))
  .join(" ");
---

<div class="tool-claim" data-tool-claim={claim.dimensionId}>
  <dt>{claim.label}</dt>
  <dd>
    <div class="tool-claim__summary">
      <span class="evidence-row__value" data-evidence-value>
        {formatDimensionValue(claim.dimension, claim.evidence.value)}
      </span>
      <EvidenceBadge state={claim.evidence.state} />
      {claim.lastCheckedAt && (
        <span class="evidence-row__date">
          Checked <time datetime={claim.lastCheckedAt}>{claim.lastCheckedAt}</time>
        </span>
      )}
    </div>
    <details class="tool-claim__details">
      <summary>Evidence details</summary>
      <dl>
        <div>
          <dt>Scope</dt>
          <dd>
            {Object.entries(claim.scope).map(([key, value]) => (
              <span>{scopeLabels[key as keyof typeof scopeLabels]}: {value}</span>
            ))}
          </dd>
        </div>
        <div>
          <dt>Resolution</dt>
          <dd>{claim.evidence.explanation}</dd>
        </div>
        <div>
          <dt>Sources</dt>
          <dd>
            {claim.sources.length > 0
              ? claim.sources.map((source) => (
                  <a
                    href={source.sourceUrl}
                    data-link-type="evidence"
                    target="_blank"
                    rel="noopener noreferrer"
                  >{sourceTypeLabel(source.sourceType)}</a>
                ))
              : <span>No selected source</span>}
          </dd>
        </div>
      </dl>
    </details>
  </dd>
</div>
