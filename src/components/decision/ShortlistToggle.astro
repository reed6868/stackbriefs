---
import type { DomainCandidate } from "../../domain/model";

interface Props {
  candidate: DomainCandidate;
}

const { candidate } = Astro.props;
---

<button
  type="button"
  class="text-button shortlist-toggle"
  data-shortlist-toggle
  data-tool-slug={candidate.tool.slug}
  data-tool-name={candidate.tool.name}
  aria-pressed="false"
  hidden
>
  Add {candidate.tool.name} to shortlist
</button>
