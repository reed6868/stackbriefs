---
import type { DimensionContent } from "../../content/schema";
import type { DecisionCondition } from "../../domain/decision";
import type { DomainScenario } from "../../domain/model";
import { dimensionOptionLabels, formatDimensionValue } from "./presentation";

interface Props {
  scenario: DomainScenario;
  conditions: readonly DecisionCondition[];
}

const operatorLabels: Record<DimensionContent["operator"], string> = {
  eq: "Must equal",
  contains: "Must include",
  lte: "At or below",
  gte: "At or above",
};

const { scenario, conditions } = Astro.props;
const active = new Map(conditions.map((condition) => [condition.dimensionId, condition]));
const dimensions = [...scenario.dimensions].sort((left, right) => left.order - right.order);
---

<aside class="criteria-panel" aria-labelledby="criteria-title">
  <div class="criteria-panel__heading">
    <p class="fixture-label">Decision criteria</p>
    <h2 id="criteria-title">Narrow the field</h2>
    <p>Review the available dimensions and supported values.</p>
  </div>
  <ol class="criteria-list">
    {dimensions.map((dimension) => {
      const condition = active.get(dimension.id);
      return (
        <li class="criterion" data-condition-mode={condition?.mode ?? "inactive"}>
          <div class="criterion__heading">
            <h3>{dimension.label}</h3>
            <span>{condition ? condition.mode : "Not applied"}</span>
          </div>
          <p>
            {condition
              ? `${operatorLabels[dimension.operator]} ${formatDimensionValue(dimension, condition.value)}`
              : `${operatorLabels[dimension.operator]} one supported value`}
          </p>
          <p class="criterion__values">Options: {dimensionOptionLabels(dimension).join(" · ")}</p>
        </li>
      );
    })}
  </ol>
</aside>
