---
import type { CandidateEvaluation } from "../../domain/decision";
import type { DomainCandidate, DomainScenario } from "../../domain/model";
import EvidenceBadge from "./EvidenceBadge.astro";
import EvidenceSummary from "./EvidenceSummary.astro";
import ShortlistToggle from "./ShortlistToggle.astro";
import { conditionExplanationText } from "./presentation";

interface Props {
  scenario: DomainScenario;
  candidate: DomainCandidate;
  evaluation: CandidateEvaluation;
}

const { scenario, candidate, evaluation } = Astro.props;
const hasConditions = evaluation.required.length + evaluation.optional.length > 0;
---

<article
  class="candidate-card"
  data-evaluation-state={evaluation.state}
  data-candidate-card={candidate.id}
>
  <div class="candidate-card__heading">
    <div>
      <p class="candidate-card__state state-label" data-state="success" data-candidate-state-label>
        {hasConditions ? "Match" : "In scope"}
      </p>
      <h3>{candidate.tool.name}</h3>
    </div>
    <div class="candidate-card__actions">
      <a href={`/tool/${candidate.tool.slug}`}>View Tool details</a>
      <ShortlistToggle candidate={candidate} />
    </div>
  </div>
  <p class="candidate-card__summary">{candidate.tool.summary}</p>
  <section
    class="candidate-explanations"
    aria-label={`Why ${candidate.tool.name} matches`}
    data-candidate-explanations
    hidden={!hasConditions}
  >
      <h4>Why it appears</h4>
      <ul data-candidate-explanation-list>
        {evaluation.explanations.map((explanation) =>
          explanation.kind === "condition" ? (
            <li data-condition-state={explanation.state}>
              <span>{conditionExplanationText(explanation)}</span>
              <EvidenceBadge state={explanation.evidenceState} />
            </li>
          ) : (
            <li class="candidate-limitation"><strong>Limitation:</strong> {explanation.text}</li>
          ))}
      </ul>
  </section>
  <p
    class="candidate-limitation"
    data-candidate-static-limitation
    hidden={hasConditions}
  >
    <strong>Limitation:</strong> {candidate.limitation}
  </p>
  <EvidenceSummary scenario={scenario} candidate={candidate} />
</article>
