---
import type { DomainScenario } from "../../domain/model";

interface Props {
  scenario: DomainScenario;
}

const { scenario } = Astro.props;
---

<header class="decision-header" data-fixture={scenario.fixture ? "true" : undefined}>
  <div class="decision-header__intro">
    <p class="fixture-label">{scenario.fixture ? "Fixture preview" : "Published Scenario"}</p>
    <h1>{scenario.title}</h1>
    <p class="decision-header__goal">{scenario.goal}</p>
    <p class="decision-header__reviewed">
      Last reviewed <time datetime={scenario.lastReviewedAt}>{scenario.lastReviewedAt}</time>
    </p>
  </div>
  <div class="decision-boundaries">
    <section aria-labelledby="decision-prerequisites">
      <h2 id="decision-prerequisites">Before you decide</h2>
      <ul>
        {scenario.prerequisites.map((prerequisite) => <li>{prerequisite}</li>)}
      </ul>
    </section>
    <dl>
      <div>
        <dt>Suitable for</dt>
        <dd>{scenario.suitableFor}</dd>
      </div>
      <div>
        <dt>Not suitable for</dt>
        <dd>{scenario.notSuitableFor}</dd>
      </div>
    </dl>
  </div>
</header>
