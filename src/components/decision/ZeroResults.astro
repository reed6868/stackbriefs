---
import type { DecisionEvaluation } from "../../domain/decision";
import type { DomainScenario } from "../../domain/model";

interface Props {
  scenario: DomainScenario;
  evaluation: DecisionEvaluation;
}

const { scenario, evaluation } = Astro.props;
const names = new Map(scenario.candidates.map((candidate) => [candidate.id, candidate.tool.name]));
---

<section
  class="zero-results"
  aria-labelledby="zero-results-title"
  data-zero-results
  hidden={evaluation.matches.length > 0}
>
    <p class="fixture-label">Recovery</p>
    <h2 id="zero-results-title">Review one requirement at a time</h2>
    <p>No requirement has been changed automatically.</p>
    <ul data-relaxation-list hidden={evaluation.relaxations.length === 0}>
        {evaluation.relaxations.map((relaxation) => (
          <li>
            <strong>Review {relaxation.label}</strong>
            <span>
              {relaxation.candidateIds.map((candidateId) => names.get(candidateId)).filter(Boolean).join(", ")}
              {" could match if this requirement changes."}
            </span>
            <button type="button" class="text-button" data-relax-dimension={relaxation.dimensionId}>
              Make {relaxation.label} optional
            </button>
          </li>
        ))}
    </ul>
    <p data-relaxation-empty hidden={evaluation.relaxations.length > 0}>
      Clear a required condition or return to the Scenario boundaries before continuing.
    </p>
  </section>
