---
import type { DecisionEvaluation } from "../../domain/decision";
import { resultSummaryText } from "./presentation";

interface Props {
  evaluation: DecisionEvaluation;
}

const { evaluation } = Astro.props;
const summary = resultSummaryText(evaluation);
---

<header id="result-summary" class="result-summary" aria-live="polite" tabindex="-1" data-result-summary>
  <p class="fixture-label">Results</p>
  <h2 data-result-heading>{summary.heading}</h2>
  <p data-result-description>{summary.description}</p>
</header>
