---
import stackbriefsMark from "../assets/stackbriefs-mark.svg";
import MobileNav from "./MobileNav.astro";
import { isCurrentPage, shellNavigation } from "./navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner site-container">
    <a class="site-brand" href="/" aria-label="StackBriefs home">
      <img src={stackbriefsMark.src} width="32" height="32" alt="" />
      <span>StackBriefs</span>
    </a>
    <nav class="desktop-nav" aria-label="Primary">
      <ul>
        {
          shellNavigation.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isCurrentPage(item.href, currentPath) ? "page" : undefined}
                data-shell-section-link={item.href === "/#scenarios" ? "" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <button
      type="button"
      class="menu-button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="site-menu"
      data-mobile-menu-trigger
    >
      <span aria-hidden="true"></span>
    </button>
  </div>
  <MobileNav currentPath={currentPath} />
</header>

<script>
  import { isCurrentSection } from "./navigation";

  const sectionLinks = document.querySelectorAll<HTMLAnchorElement>("[data-shell-section-link]");

  const updateSectionState = () => {
    const currentUrl = new URL(window.location.href);

    sectionLinks.forEach((link) => {
      if (isCurrentSection(link.href, currentUrl)) {
        link.setAttribute("aria-current", "location");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  };

  updateSectionState();
  window.addEventListener("hashchange", updateSectionState);
</script>
