---
import type { BreadcrumbItem } from "../components/Breadcrumbs.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { publicationOptionsFromEnvironment } from "../content/build-context";
import {
  buildStructuredData,
  canonicalUrl,
  serializeStructuredData,
  type SeoContent,
} from "../domain/seo";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  reading?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  seoBreadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
  indexable?: boolean;
  canonicalPath?: string;
  structuredData?: SeoContent | undefined;
}

const {
  title,
  description,
  reading = false,
  breadcrumbs,
  seoBreadcrumbs = breadcrumbs,
  noindex = false,
  indexable = publicationOptionsFromEnvironment().target === "production",
  canonicalPath = Astro.url.pathname,
  structuredData,
} = Astro.props;
const currentPath = Astro.url.pathname;
const mainClass = ["page-content", "site-container", reading && "reading-layout"].filter(Boolean).join(" ");
const isIndexable = indexable && !noindex;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = isIndexable ? canonicalUrl(site, canonicalPath) : undefined;
const serializedStructuredData = canonical && structuredData
  ? serializeStructuredData(buildStructuredData({
      title,
      description,
      canonicalUrl: canonical,
      site,
      breadcrumbs: seoBreadcrumbs,
      content: structuredData,
    }))
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {!isIndexable && <meta name="robots" content="noindex, nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:site_name" content="StackBriefs" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#F7F8FA" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="preload"
      href="/fonts/geist-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    {serializedStructuredData && (
      <script is:inline type="application/ld+json" set:html={serializedStructuredData} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <SiteHeader currentPath={currentPath} />
    <main id="main-content" class={mainClass} tabindex="-1">
      {breadcrumbs && <Breadcrumbs items={breadcrumbs} />}
      <slot />
    </main>
    <SiteFooter currentPath={currentPath} />
  </body>
</html>
