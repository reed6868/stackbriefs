{
  "name": "stackbriefs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check && tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:schema": "vitest run tests/content-schema.test.ts",
    "test:browser": "playwright test && playwright test --config=playwright.lifecycle.config.ts",
    "test:browser:core": "playwright test --project=chromium --project=webkit",
    "test:browser:lifecycle": "playwright test --config=playwright.lifecycle.config.ts",
    "test:browser:firefox": "playwright test tests/browser/home-to-decision.test.ts --project=firefox-smoke",
    "test:browser:smoke": "playwright test tests/browser/home-to-decision.test.ts --project=chromium",
    "validate:structured-data": "node tests/support/validate-structured-data.ts",
    "build": "astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/mdx": "7.0.2",
    "@astrojs/sitemap": "3.7.3",
    "@tailwindcss/vite": "4.3.2",
    "astro": "7.0.7",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
